{
  "name": "cognexia",
  "version": "2.3.0",
  "description": "Long-term memory for AI agents. Data Lake Edition with project-based isolation.",
  "main": "electron/main.js",
  "bin": {
    "cognexia": "./cli.js"
  },
  "scripts": {
    "test": "jest",
    "init": "node scripts/init.js",
    "start": "node server.js",
    "start:electron": "electron .",
    "build:electron": "electron-builder",
    "build:electron:mac": "electron-builder --mac",
    "build:electron:win": "electron-builder --win",
    "build:electron:linux": "electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "ai",
    "agent",
    "memory",
    "openclaw",
    "persistence",
    "context",
    "llm"
  ],
  "author": "Ares",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "compromise": "^14.10.0",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.6"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "png2icons": "^2.0.1"
  },
  "build": {
    "appId": "com.cognexia.app",
    "productName": "Cognexia",
    "copyright": "Copyright © 2024 Ares",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "server.js",
      "electron/**",
      "public/**",
      "node_modules/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server.js",
        "to": "server.js"
      },
      {
        "from": "public",
        "to": "public"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "icon": "build/icon.icns",
      "artifactName": "${productName}-${version}-mac.${ext}"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-win.${ext}"
    },
    "linux": {
      "category": "Utility",
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "artifactName": "${productName}-${version}-linux.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cognexia"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nKOxxx/Cognexia.git"
  }
}
